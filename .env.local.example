#webhook
VERIFY_TOKEN=your-webhook-verify-token

#flow
PRIVATE_KEY_PATH=./private_unencrypted_pkcs8.pem

#test phone number
PHONE_NUMBER_ID=your-whatsapp-phone-number-id
WHATSAPP_TOKEN=your-whatsapp-business-account-token
TEST_PHONE_NUMBER=your-test-phone-number

#brevo
BREVO_API_KEY=your-brevo-api-key
MAIL_SENDER_EMAIL=your-email@domain.com
MAIL_SENDER_NAME=Your Business Name
BASE_URL=http://localhost:3000/reset_code

#Plugin key
WP_PLUGIN_BASE_URL=http://localhost/ILEYCOM/wordpress/wp-json/whatsapp-bot/v1
WP_PLUGIN_API_KEY=your-wordpress-plugin-api-key
WP_PLUGIN_TIMEOUT_MS=30000

#redis
REDIS_ENABLED=true
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ileycom:seller-bot:local

#hashing
PIN_PEPPER="your-secret-pin-pepper-string"

#local WordPress filesystem root (Apache document root) for fast image access
WP_LOCAL_DOC_ROOT=C:\xampp\htdocs
